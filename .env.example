# Discord OAuth Configuration
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Discord Guild ID (Server ID)
# Right-click your server in Discord and copy ID (Developer Mode must be enabled)
DISCORD_GUILD_ID=your_discord_guild_id_here

# ============================================
# ДЛЯ ПРОДАКШЕНА НА VERCEL:
# ============================================
# 1. Создайте новое Discord приложение для продакшена
# 2. Сгенерируйте новый NEXTAUTH_SECRET: 
#    node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 3. NEXTAUTH_URL должен быть вашим доменом Vercel
# 4. Добавьте все переменные в Vercel Environment Variables
# 5. НЕ используйте секреты из .env.local для продакшена!

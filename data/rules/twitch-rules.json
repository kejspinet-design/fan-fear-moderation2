{
  "version": "3.0.0",
  "lastModified": "2024-01-15T00:00:00.000Z",
  "sections": [
    {
      "id": "twitch-penalties",
      "title": "Шкала наказаний",
      "description": "От мягкого к жёсткому",
      "rules": [
        {
          "id": "twitch-penalty-1",
          "number": "Н.1",
          "title": "Капс, спам сообщений",
          "text": "Капс, 5+ сообщений подряд, клавиатурный спам (asdfgh)",
          "penalty": "/timeout @ник 10 (10 секунд)"
        },
        {
          "id": "twitch-penalty-2",
          "number": "Н.2",
          "title": "Спам ссылками",
          "text": "Спам ссылками (кроме youtube/twitch/steam)",
          "penalty": "/timeout @ник 1h + удалить ссылку"
        },
        {
          "id": "twitch-penalty-3",
          "number": "Н.3",
          "title": "Мелкая токсичность",
          "text": "«Стример лох», «игра говно»",
          "penalty": "/timeout @ник 10m"
        },
        {
          "id": "twitch-penalty-4",
          "number": "Н.4",
          "title": "Спойлеры",
          "text": "Спойлеры сюжета (если стрим по сюжетке)",
          "penalty": "/timeout @ник 1h"
        },
        {
          "id": "twitch-penalty-5",
          "number": "Н.5",
          "title": "Оскорбления",
          "text": "Оскорбление зрителя / мода / стримера",
          "penalty": "/timeout @ник 24h или /ban при повторе"
        },
        {
          "id": "twitch-penalty-6",
          "number": "Н.6",
          "title": "Реклама стримов",
          "text": "Реклама другого стрима во время эфира",
          "penalty": "/ban @ник (навсегда, без права апелляции)"
        },
        {
          "id": "twitch-penalty-7",
          "number": "Н.7",
          "title": "Экстремизм",
          "text": "Расизм, нацизм, призывы к насилию",
          "penalty": "/ban @ник (немедленно)"
        }
      ]
    },
    {
      "id": "twitch-mods-call",
      "title": "Действия при вызове модов",
      "description": "Что делать, если зритель позвал модов (через @mods)",
      "rules": [
        {
          "id": "twitch-mods-1",
          "number": "М.1",
          "title": "Отмотать чат",
          "text": "Отмотайте чат назад на 1–2 минуты",
          "penalty": null
        },
        {
          "id": "twitch-mods-2",
          "number": "М.2",
          "title": "Найти конфликт",
          "text": "Найдите конфликт",
          "penalty": null
        },
        {
          "id": "twitch-mods-3",
          "number": "М.3",
          "title": "Наказать агрессора",
          "text": "Накажите агрессора (не разбирайте «кто первый начал»)",
          "penalty": null
        },
        {
          "id": "twitch-mods-4",
          "number": "М.4",
          "title": "Ответить",
          "text": "Ответьте коротко: @ник_зрителя, нарушитель получил таймаут, спасибо",
          "penalty": null
        }
      ]
    },
    {
      "id": "twitch-forbidden",
      "title": "Что модератору делать запрещено",
      "rules": [
        {
          "id": "twitch-forbidden-1",
          "number": "З.1",
          "title": "Спорить в чате",
          "text": "Спорить с нарушителем в чате. Вместо диалога — /timeout",
          "penalty": "Выговор"
        },
        {
          "id": "twitch-forbidden-2",
          "number": "З.2",
          "title": "Мут без причины",
          "text": "Давать мут без причины («не нравится имя», «показалось»)",
          "penalty": "Выговор"
        },
        {
          "id": "twitch-forbidden-3",
          "number": "З.3",
          "title": "Троллинг",
          "text": "Троллить зрителей от имени модератора",
          "penalty": "Выговор"
        },
        {
          "id": "twitch-forbidden-4",
          "number": "З.4",
          "title": "Игнорирование",
          "text": "Игнорировать рекламу и ботов",
          "penalty": "Выговор"
        }
      ]
    },
    {
      "id": "twitch-interaction",
      "title": "Взаимодействие",
      "rules": [
        {
          "id": "twitch-interaction-1",
          "number": "В.1",
          "title": "Стример онлайн",
          "text": "Если стример онлайн — не противоречьте ему публично. Личные вопросы пишите в личку или в приватный чат модов",
          "penalty": null
        },
        {
          "id": "twitch-interaction-2",
          "number": "В.2",
          "title": "Другие моды",
          "text": "Не отменяйте наказание другого мода, не поговорив с ним сначала",
          "penalty": null
        },
        {
          "id": "twitch-interaction-3",
          "number": "В.3",
          "title": "Ошибки",
          "text": "Если ошиблись — признайте ошибку и размутите человека",
          "penalty": null
        }
      ]
    },
    {
      "id": "twitch-commands",
      "title": "Технические команды",
      "description": "Быстрая памятка",
      "rules": [
        {
          "id": "twitch-cmd-1",
          "number": "К.1",
          "title": "Таймаут секунды/минуты",
          "text": "/timeout @ник 30 (30 секунд)",
          "penalty": null
        },
        {
          "id": "twitch-cmd-2",
          "number": "К.2",
          "title": "Таймаут часы",
          "text": "/timeout @ник 1h",
          "penalty": null
        },
        {
          "id": "twitch-cmd-3",
          "number": "К.3",
          "title": "Бан",
          "text": "/ban @ник",
          "penalty": null
        },
        {
          "id": "twitch-cmd-4",
          "number": "К.4",
          "title": "Разбан",
          "text": "/unban @ник",
          "penalty": null
        },
        {
          "id": "twitch-cmd-5",
          "number": "К.5",
          "title": "Очистить чат",
          "text": "/clear",
          "penalty": null
        }
      ]
    },
    {
      "id": "twitch-emergency",
      "title": "Экстренные ситуации",
      "rules": [
        {
          "id": "twitch-emergency-1",
          "number": "Э.1",
          "title": "Спам-боты",
          "text": "Поток спам-ботов: /clear, /ban каждого, включите проверку телефона/почты в настройках канала",
          "penalty": null
        },
        {
          "id": "twitch-emergency-2",
          "number": "Э.2",
          "title": "Личные данные",
          "text": "Пишут адрес или личные данные стримера: /ban навсегда, сделайте скрин, сообщите стримеру",
          "penalty": null
        },
        {
          "id": "twitch-emergency-3",
          "number": "Э.3",
          "title": "Суицид",
          "text": "Зритель пишет о суициде: Не банить! Напишите в чат: «@ник, напиши мне в личку». В личке предложите помощь (психологическая линия)",
          "penalty": null
        }
      ]
    },
    {
      "id": "twitch-warnings",
      "title": "Выговоры",
      "rules": [
        {
          "id": "twitch-warning-1",
          "number": "ВГ.1",
          "title": "Долгое отсутствие",
          "text": "Долгое отсутствие без весомых причин",
          "penalty": "Выговор снимается спустя месяц, при условии что модератор присутствовал на всех стримах"
        },
        {
          "id": "twitch-warning-2",
          "number": "ВГ.2",
          "title": "Неадекватное поведение",
          "text": "Неадекватное поведение в чате",
          "penalty": "Выговор снимается спустя месяц по решению руководства"
        },
        {
          "id": "twitch-warning-3",
          "number": "ВГ.3",
          "title": "Халатность",
          "text": "Халатность в выполнении обязанностей модератора",
          "penalty": "Выговор снимается спустя месяц по решению руководства"
        },
        {
          "id": "twitch-warning-4",
          "number": "ВГ.4",
          "title": "Использование функций",
          "text": "Использование функций модератора в своих целях",
          "penalty": "Выговор снимается спустя месяц, при условии что модератор делал правильные наказания и не получал выговоры"
        }
      ]
    }
  ]
}
